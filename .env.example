# Coverage Manager Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
#
# Production: set these directly in the environment. The C# API binds via
# .NET config (double-underscore = config section separator), so the keys
# ASP.NET Core will actually read are:
#
#   Supabase__Url   <- becomes IConfiguration["Supabase:Url"]
#   Supabase__Key   <- becomes IConfiguration["Supabase:Key"]
#
# Dev (Windows): prefer `dotnet user-secrets` scoped to the Api project:
#   cd src/CoverageManager.Api
#   dotnet user-secrets init
#   dotnet user-secrets set "Supabase:Key" "eyJ..."
#
# The Python collector reads the plain SUPABASE_* names below.

# Supabase (ASP.NET picks up the __ variants; Python picks up the plain ones)
SUPABASE_URL=https://svhmhcqopkdgccnzgvzp.supabase.co
SUPABASE_KEY=
Supabase__Url=https://svhmhcqopkdgccnzgvzp.supabase.co
Supabase__Key=

# MT5 Manager API (B-Book)
MT5_MANAGER_SERVER=
MT5_MANAGER_LOGIN=
MT5_MANAGER_PASSWORD=

# MT5 Coverage Terminal (Python Collector)
MT5_COVERAGE_LOGIN=96900
MT5_COVERAGE_SERVER=194.164.176.137:443
MT5_COVERAGE_PASSWORD=

# Server Ports
BACKEND_PORT=5000
COLLECTOR_PORT=8100
FRONTEND_PORT=5173
