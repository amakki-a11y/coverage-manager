{
  "asyncapi": "2.6.0",
  "defaultContentType": "application/json",
  "info": {
    "title": "CS 360 Websocket API",
    "version": "1.7.0",
    "description": "This is the CS 360 Websocket API documentation.\n"
  },
  "servers": {
    "production": {
      "url": "wss://bridge.centroidsol.com/ws?token={token}&q={client_code}",
      "protocol": "wss",
      "variables": {
        "token": {
          "description": "The token to authenticate the user."
        },
        "client_code": {
          "description": "The client code to authenticate the user."
        }
      },
      "security": [
        {
          "apiKey": []
        }
      ]
    }
  },
